@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "🔐 Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .password-container {
        max-width: 700px;
        margin: auto;
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        margin-top: 50px;
        margin-bottom: 50px;
    }

    .header-section {
        text-align: center;
        margin-bottom: 40px;
        padding-bottom: 30px;
        border-bottom: 2px solid #f0f0f0;
    }

    .header-section h3 {
        color: #2d3748;
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .header-section p {
        color: #718096;
        font-size: 1.1rem;
        margin: 0;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 16px;
        border: 2px solid #e2e8f0;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

    .form-control:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .form-floating > .form-control {
        height: calc(3.5rem + 2px);
        padding: 1rem 0.75rem;
    }

    .form-floating > label {
        padding: 1rem 0.75rem;
    }

    .btn-primary {
        border-radius: 12px;
        padding: 14px 30px;
        font-weight: 600;
        font-size: 1.1rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        transition: all 0.3s ease;
        width: 100%;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
    }

    .form-label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
    }

    .password-strength {
        margin-top: 5px;
        font-size: 0.875rem;
    }

    .password-strength.weak {
        color: #e53e3e;
    }

    .password-strength.medium {
        color: #dd6b20;
    }

    .password-strength.strong {
        color: #38a169;
    }

    .card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .input-group-text {
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-left: none;
        color: #4a5568;
    }

    .security-tips {
        background: #f7fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px;
        margin-top: 30px;
    }

    .security-tips h6 {
        color: #2d3748;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .security-tips ul {
        margin: 0;
        padding-left: 20px;
    }

    .security-tips li {
        color: #4a5568;
        margin-bottom: 8px;
    }

    @@media(max-width:768px){
        .password-container {
            padding: 25px;
            margin: 20px;
        }

        .header-section h3 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="password-container">
    <div class="header-section">
        <h3><i class="bi bi-shield-lock me-2"></i>@ViewData["Title"]</h3>
        <p>Keep your account secure with a strong password</p>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="card">
        <div class="card-body p-4">
            <form id="change-password-form" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Please enter your old password." />
                    <label asp-for="Input.OldPassword" class="form-label">
                        <i class="bi bi-key me-1"></i>Current Password
                    </label>
                    <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Please enter your new password." />
                    <label asp-for="Input.NewPassword" class="form-label">
                        <i class="bi bi-lock me-1"></i>New Password
                    </label>
                    <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Please confirm your new password."/>
                    <label asp-for="Input.ConfirmPassword" class="form-label">
                        <i class="bi bi-lock-fill me-1"></i>Confirm New Password
                    </label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-2"></i>Update Password
                </button>
            </form>
        </div>
    </div>

    <!-- Security Tips -->
    <div class="security-tips">
        <h6><i class="bi bi-info-circle me-2"></i>Password Security Tips</h6>
        <ul>
            <li>Use at least 8 characters with a mix of letters, numbers, and symbols</li>
            <li>Avoid using personal information like your name or birthdate</li>
            <li>Don't reuse passwords from other accounts</li>
            <li>Consider using a password manager for secure password generation</li>
        </ul>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}



