@page
@model IndexModel
@{
    ViewData["Title"] = "👤 Profile";
}

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .profile-container {
        max-width: 900px;
        margin: auto;
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        margin-top: 50px;
        margin-bottom: 50px;
    }

    .top-section {
        display: flex;
        align-items: center;
        gap: 25px;
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 30px;
        margin-bottom: 30px;
    }

    .avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        font-size: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
        border: 4px solid white;
    }

    .info h4 {
        margin: 0;
        color: #2d3748;
        font-size: 1.8rem;
        font-weight: 700;
    }

    .info small {
        color: #718096;
        font-size: 1rem;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 16px;
        border: 2px solid #e2e8f0;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

    .form-control:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .btn-save {
        border-radius: 12px;
        width: 100%;
        padding: 14px;
        font-weight: 600;
        font-size: 1.1rem;
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        transition: all 0.3s ease;
        margin-top: 20px;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
    }

    .menu {
        display: flex;
        gap: 15px;
        margin-bottom: 30px;
        flex-wrap: wrap;
    }

    .menu a {
        padding: 12px 20px;
        border-radius: 12px;
        text-decoration: none;
        background: #f8fafc;
        color: #4a5568;
        font-weight: 500;
        transition: all 0.3s ease;
        border: 2px solid transparent;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .menu a:hover {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.2);
    }

    .menu a.active {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border-color: #667eea;
    }

    .form-label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
    }

    .card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    @@media(max-width:768px){
        .top-section{
            flex-direction: column;
            text-align: center;
            gap: 20px;
        }

        .menu{
            flex-direction: column;
        }

        .profile-container {
            padding: 25px;
            margin: 20px;
        }

        .avatar {
            width: 80px;
            height: 80px;
            font-size: 28px;
        }

        .info h4 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="profile-container">

    <!-- TOP USER INFO -->
    <div class="top-section">
        <div class="avatar">
            @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "?")
        </div>

        <div class="info">
            <h4>@User.Identity?.Name</h4>
            <small>👋 Welcome to your account dashboard</small>
        </div>
    </div>

    <!-- MENU (NO DUPLICATE SIDEBAR) -->
    <div class="menu">
        <a asp-page="./Index" class="active">
            <i class="bi bi-person-circle"></i> Profile
        </a>
        <a asp-page="./Email">
            <i class="bi bi-envelope"></i> Email
        </a>
        <a asp-page="./ChangePassword">
            <i class="bi bi-key"></i> Password
        </a>
        <a asp-page="./PersonalData">
            <i class="bi bi-shield-lock"></i> Data & Privacy
        </a>
    </div>

    <!-- FORM -->
    <div class="card">
        <div class="card-body p-4">
            <h5 class="card-title mb-4">
                <i class="bi bi-pencil-square me-2"></i>Edit Profile Information
            </h5>

            <form method="post">
                <div class="mb-4">
                    <label class="form-label">
                        <i class="bi bi-person me-1"></i>Username
                    </label>
                    <input asp-for="Username" class="form-control" disabled />
                    <small class="text-muted">Username cannot be changed</small>
                </div>

                <div class="mb-4">
                    <label class="form-label">
                        <i class="bi bi-telephone me-1"></i>Phone Number
                    </label>
                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Enter your phone number" />
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-save">
                    <i class="bi bi-check-circle me-2"></i>Save Changes
                </button>
            </form>
        </div>
    </div>

</div>


