@model HomeViewModel
@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-gradient-info text-white text-center py-4">
            <i class="bi bi-search fs-1 mb-2"></i>
            <h3 class="mb-0">Advanced Book Search</h3>
            <p class="mb-0">Find your perfect book with our powerful filters</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="mb-4 p-3 bg-light rounded-3">
                <h5 class="mb-3"><i class="bi bi-funnel"></i> Search Filters</h5>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="title" class="form-label fw-bold">Book Title</label>
                        <input type="text" name="title" value="@ViewBag.Title" class="form-control" placeholder="Enter book title..." />
                    </div>
                    <div class="col-md-3">
                        <label for="author" class="form-label fw-bold">Author</label>
                        <input type="text" name="author" value="@ViewBag.Author" class="form-control" placeholder="Enter author name..." />
                    </div>
                    <div class="col-md-2">
                        <label for="genreId" class="form-label fw-bold">Genre</label>
                        <select name="genreId" class="form-select">
                            <option value="0">All Genres</option>
                            @foreach (var genre in Model.Genres)
                            {
                                <option value="@genre.Id" selected="@(Model.GenreId == genre.Id ? "selected" : null)">@genre.GenreName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="minPrice" class="form-label fw-bold">Min Price</label>
                        <input type="number" name="minPrice" value="@ViewBag.MinPrice" step="0.01" class="form-control" placeholder="0.00" />
                    </div>
                    <div class="col-md-2">
                        <label for="maxPrice" class="form-label fw-bold">Max Price</label>
                        <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" step="0.01" class="form-control" placeholder="1000.00" />
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-md-3">
                        <label for="sortBy" class="form-label fw-bold">Sort By</label>
                        <select name="sortBy" class="form-select">
                            <option value="">Default</option>
                            <option value="price_low" selected="@(ViewBag.SortBy == "price_low" ? "selected" : null)">Price: Low to High</option>
                            <option value="price_high" selected="@(ViewBag.SortBy == "price_high" ? "selected" : null)">Price: High to Low</option>
                            <option value="title" selected="@(ViewBag.SortBy == "title" ? "selected" : null)">Title A-Z</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-search"></i> Search Books
                        </button>
                    </div>
                </div>
            </form>

            @if (Model.Books.Any())
            {
                <div class="row">
                    @foreach (var book in Model.Books)
                    {
                        <div class="col-md-4 mb-4">
                            <div class="card h-100 shadow-sm hover-card">
                                <img src="~/images/@book.Image" class="card-img-top" alt="@book.BookName" style="height: 200px; object-fit: cover;" />
                                <div class="card-body">
                                    <h5 class="card-title">@book.BookName</h5>
                                    <p class="card-text text-muted">by @book.AuthorName</p>
                                    <p class="card-text fw-bold text-primary">$@book.Price</p>
                                    <a href="/Book/Details/@book.Id" class="btn btn-outline-primary w-100">
                                        <i class="bi bi-eye"></i> View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-search text-muted fs-1 mb-3"></i>
                    <h4 class="text-muted">No books found</h4>
                    <p class="text-muted">Try adjusting your search criteria.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .bg-gradient-info {
        background: linear-gradient(135deg, #74b9ff 0%, #0984e3 100%);
    }
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }
</style>