@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <!-- Hero Section -->
    <div class="card shadow-lg border-0 rounded-3 mb-5">
        <div class="card-body text-center py-5 bg-gradient-secondary">
            <i class="bi bi-book-half text-white fs-1 mb-3"></i>
            <h1 class="display-4 text-white mb-3">About DSJ's BookStore</h1>
            <p class="lead text-white-50 mb-0">Your gateway to a world of knowledge and imagination</p>
        </div>
    </div>

    <!-- Mission Section -->
    <div class="row mb-5">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-3 h-100">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="bi bi-bullseye text-primary fs-1"></i>
                        <h3 class="mt-3">Our Mission</h3>
                    </div>
                    <p class="lead">To provide quality books at affordable prices and foster a love for reading in our community. We believe that books have the power to change lives and open minds to new possibilities.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-3 h-100">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="bi bi-eye text-success fs-1"></i>
                        <h3 class="mt-3">Our Vision</h3>
                    </div>
                    <p class="lead">To become the leading online bookstore that connects readers with their next great adventure. We strive to create a platform where book lovers can discover, share, and celebrate the joy of reading.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Section -->
    <div class="card shadow-lg border-0 rounded-3 mb-5">
        <div class="card-body py-5">
            <div class="row text-center">
                <div class="col-md-3">
                    <div class="stat-item">
                        <i class="bi bi-book text-primary fs-2 mb-2"></i>
                        <h2 class="counter">10,000+</h2>
                        <p class="text-muted">Books Available</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <i class="bi bi-people text-success fs-2 mb-2"></i>
                        <h2 class="counter">50,000+</h2>
                        <p class="text-muted">Happy Customers</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <i class="bi bi-star text-warning fs-2 mb-2"></i>
                        <h2 class="counter">4.8</h2>
                        <p class="text-muted">Average Rating</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-item">
                        <i class="bi bi-calendar text-info fs-2 mb-2"></i>
                        <h2 class="counter">5+</h2>
                        <p class="text-muted">Years of Service</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Team Section -->
    <div class="card shadow-lg border-0 rounded-3 mb-5">
        <div class="card-header bg-light text-center py-4">
            <h3 class="mb-0"><i class="bi bi-people-fill"></i> Meet Our Team</h3>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-4 text-center mb-4">
                    <div class="team-member">
                        <div class="avatar mb-3">
                            <i class="bi bi-person-circle text-primary fs-1"></i>
                        </div>
                        <h5>Debodipto Samadder</h5>
                        <p class="text-muted">Founder & CEO</p>
                        <p>Passionate about books and technology, Debodipto founded DSJ's BookStore to make reading accessible to everyone.</p>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-4">
                    <div class="team-member">
                        <div class="avatar mb-3">
                            <i class="bi bi-person-circle text-success fs-1"></i>
                        </div>
                        <h5>Sarah Johnson</h5>
                        <p class="text-muted">Head Curator</p>
                        <p>With 10+ years in publishing, Sarah ensures our collection features the best books from around the world.</p>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-4">
                    <div class="team-member">
                        <div class="avatar mb-3">
                            <i class="bi bi-person-circle text-info fs-1"></i>
                        </div>
                        <h5>Mike Chen</h5>
                        <p class="text-muted">Tech Lead</p>
                        <p>Mike handles all technical aspects, ensuring our platform is fast, secure, and user-friendly.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Testimonials -->
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-light text-center py-4">
            <h3 class="mb-0"><i class="bi bi-chat-quote"></i> What Our Customers Say</h3>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="testimonial text-center">
                        <div class="rating mb-3">
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                        </div>
                        <p class="mb-3">"Amazing selection and fast delivery. Found all the books I needed for my studies!"</p>
                        <cite>- Emily Davis, Student</cite>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="testimonial text-center">
                        <div class="rating mb-3">
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                        </div>
                        <p class="mb-3">"The recommendations are spot on! I've discovered so many new authors thanks to this site."</p>
                        <cite>- Robert Wilson, Book Lover</cite>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="testimonial text-center">
                        <div class="rating mb-3">
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                            <i class="bi bi-star-fill text-warning"></i>
                        </div>
                        <p class="mb-3">"Excellent customer service and beautiful website. My go-to place for books!"</p>
                        <cite>- Lisa Thompson, Teacher</cite>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-secondary {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
    }
    .stat-item h2 {
        font-size: 3rem;
        font-weight: bold;
        color: #495057;
    }
    .team-member .avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #e9ecef, #dee2e6);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }
    .testimonial {
        padding: 20px;
        border: 1px solid #e9ecef;
        border-radius: 10px;
        background: #f8f9fa;
    }
    .rating .bi-star-fill {
        font-size: 1.2rem;
    }
</style>