@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-gradient-danger text-white text-center py-4">
                    <i class="bi bi-envelope-fill fs-1 mb-2"></i>
                    <h3 class="card-title mb-0">Get In Touch</h3>
                    <p class="mb-0">We'd love to hear from you</p>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    <form asp-action="Index" method="post" class="needs-validation" novalidate>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="name" class="form-label fw-bold">
                                    <i class="bi bi-person"></i> Full Name
                                </label>
                                <input type="text" name="name" class="form-control form-control-lg" required placeholder="Your full name" />
                                <div class="invalid-feedback">
                                    Please provide your name.
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="email" class="form-label fw-bold">
                                    <i class="bi bi-envelope"></i> Email Address
                                </label>
                                <input type="email" name="email" class="form-control form-control-lg" required placeholder="your@email.com" />
                                <div class="invalid-feedback">
                                    Please provide a valid email.
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="message" class="form-label fw-bold">
                                <i class="bi bi-chat-text"></i> Message
                            </label>
                            <textarea name="message" class="form-control form-control-lg" rows="5" required placeholder="Tell us how we can help you..."></textarea>
                            <div class="invalid-feedback">
                                Please enter your message.
                            </div>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-send"></i> Send Message
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-lg border-0 rounded-3 mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Contact Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-geo-alt text-danger"></i>
                        <strong>Address:</strong><br>
                        Kalabagan, Dhaka, Bangladesh
                    </div>
                    <div class="mb-3">
                        <i class="bi bi-telephone text-success"></i>
                        <strong>Phone:</strong><br>
                        (+880) 1580-357837
                    </div>
                    <div class="mb-3">
                        <i class="bi bi-envelope text-primary"></i>
                        <strong>Email:</strong><br>
                        debodiptosamadder@gmail.com
                    </div>
                    <div class="mb-3">
                        <i class="bi bi-clock text-warning"></i>
                        <strong>Hours:</strong><br>
                        Mon-Fri: 9AM-6PM<br>
                        Sat-Sun: 10AM-4PM
                    </div>
                </div>
            </div>

            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-share"></i> Follow Us</h5>
                </div>
                <div class="card-body text-center">
                    <a href="#" class="btn btn-outline-primary btn-lg me-2 mb-2">
                        <i class="bi bi-facebook"></i>
                    </a>
                    <a href="#" class="btn btn-outline-info btn-lg me-2 mb-2">
                        <i class="bi bi-twitter"></i>
                    </a>
                    <a href="#" class="btn btn-outline-danger btn-lg me-2 mb-2">
                        <i class="bi bi-instagram"></i>
                    </a>
                    <a href="#" class="btn btn-outline-dark btn-lg mb-2">
                        <i class="bi bi-youtube"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Map Section -->
    <div class="card shadow-lg border-0 rounded-3 mt-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Find Us</h5>
        </div>
        <div class="card-body p-0">
            <div class="ratio ratio-16x9">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3022.1!2d-73.9!3d40.7!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDAuNzAwMDAw!5e0!3m2!1sen!2sus!4v1234567890!5m2!1sen!2sus" 
                        allowfullscreen="" loading="lazy"></iframe>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-danger {
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
    }
    .card {
        transition: transform 0.3s ease;
    }
    .card:hover {
        transform: translateY(-2px);
    }
</style>