@model HomeViewModel
@{
    Layout = "_Layout";
    var isAdminUser = User.IsInRole("Admin")
        || string.Equals(User.Identity?.Name, "admin@gmail.com", StringComparison.OrdinalIgnoreCase);
}

@Html.AntiForgeryToken()

<style>
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* TOP SEARCH BAR */
    .search-filters-container {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        margin-bottom: 30px;
    }

    .search-filters-form .form-control,
    .search-filters-form .form-select {
        border-radius: 10px;
        border: 2px solid #e2e8f0;
        padding: 12px 16px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .search-filters-form .form-control:focus,
    .search-filters-form .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .search-filters-form .input-group-text {
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-right: none;
        color: #4a5568;
    }

    .search-filters-form .btn-primary {
        border-radius: 10px;
        padding: 12px 24px;
        font-weight: 600;
        background: linear-gradient(135deg, #667eea, #764ba2);
        border: none;
        transition: all 0.3s ease;
    }

    .search-filters-form .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
    }

    /* HERO */
    .hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 60px 40px;
        border-radius: 20px;
        margin-bottom: 30px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="50" cy="50" r="2" fill="rgba(255,255,255,0.1)"/></svg>');
        animation: float 20s infinite linear;
    }

    @@keyframes float {
        0% { transform: translateX(-50%) translateY(-50%); }
        100% { transform: translateX(-50%) translateY(-50%) translateX(100px) translateY(100px); }
    }

    .hero h2 {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 10px;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .hero p {
        font-size: 1.2rem;
        opacity: 0.9;
    }

    .admin-quick-panel {
        background: linear-gradient(135deg, #111827 0%, #1f2937 100%);
        color: white;
        padding: 24px;
        border-radius: 18px;
        margin-bottom: 25px;
        box-shadow: 0 10px 30px rgba(17, 24, 39, 0.25);
    }

    .admin-quick-panel h4 {
        font-weight: 700;
        margin-bottom: 8px;
    }

    .admin-shortcuts {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 18px;
    }

    .admin-shortcuts a {
        text-decoration: none;
        border-radius: 999px;
        padding: 10px 16px;
        font-weight: 600;
    }

    /* LAYOUT */
    .shop-layout {
        display: grid;
        grid-template-columns: 250px 1fr;
        gap: 20px;
    }

    /* SIDEBAR */
    .sidebar {
        background: white;
        padding: 15px;
        border-radius: 12px;
        height: fit-content;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .sidebar h5 {
        margin-bottom: 10px;
        font-weight: 700;
    }

    .category-item {
        padding: 8px;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.2s;
    }

    .category-item:hover {
        background: #0d6efd;
        color: white;
    }

    /* BOOK GRID */
    .book-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
    }

    .book-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .book-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    }

    .book-img {
        height: 200px;
        width: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .book-card:hover .book-img {
        transform: scale(1.05);
    }

    .book-body {
        padding: 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .title {
        font-size: 18px;
        font-weight: 700;
        color: #333;
        margin-bottom: 8px;
        line-height: 1.3;
    }

    .author {
        font-size: 14px;
        color: #666;
        margin-bottom: 15px;
        font-style: italic;
    }

    .price {
        color: #28a745;
        font-weight: bold;
        font-size: 20px;
        margin-bottom: 15px;
    }

    .btn-cart {
        border-radius: 25px;
        padding: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-cart:hover {
        transform: scale(1.02);
    }

    .wishlist-btn {
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .wishlist-btn:hover {
        transform: scale(1.1);
    }

    /* DARK MODE SUPPORT */
    body.dark-mode .sidebar,
    body.dark-mode .book-card {
        background: #1e293b;
        color: white;
    }

    body.dark-mode .category-item:hover {
        background: #38bdf8;
    }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .shop-layout {
            grid-template-columns: 1fr;
        }

        .sidebar {
            display: none;
        }
    }
</style>

<!-- HERO -->
<div class="hero text-center">
    <h2>📚 DSJ's Book Store</h2>
    <p>Find your favorite book at best price</p>
</div>

@if (isAdminUser)
{
    <div class="admin-quick-panel">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div>
                <h4>Admin Section</h4>
                <p class="mb-0 text-white-50">Manage the admin panel, orders, books, stock, and reports directly from the home page.</p>
            </div>
            <a href="/AdminOperations/Dashboard" class="btn btn-warning fw-bold text-dark">
                <i class="bi bi-speedometer2 me-1"></i> Open Admin Panel
            </a>
        </div>

        <div class="admin-shortcuts">
            <a href="/AdminOperations/AllOrders" class="btn btn-outline-light">Orders</a>
            <a href="/Book/Index" class="btn btn-outline-light">Books</a>
            <a href="/Genre/Index" class="btn btn-outline-light">Genres</a>
            <a href="/Stock/Index" class="btn btn-outline-light">Stock</a>
            <a href="/Analytics/Dashboard" class="btn btn-outline-light">Analytics</a>
            <a href="/Reports/TopFiveSellingBooks" class="btn btn-outline-light">Reports</a>
        </div>
    </div>
}

<!-- SEARCH + FILTER -->
<div class="search-filters-container mb-4">
    <form method="get" class="search-filters-form">
        <div class="row g-3">
            <!-- Search Input -->
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text"
                           name="sterm"
                           value="@Model.STerm"
                           class="form-control"
                           placeholder="Search books by title or author..." />
                </div>
            </div>

            <!-- Genre Filter -->
            <div class="col-md-2">
                <select name="genreId" class="form-select">
                    <option value="0">📚 All Genres</option>
                    @foreach (var genre in Model.Genres)
                    {
                        <option value="@genre.Id" selected="@(genre.Id == Model.GenreId)">
                            @genre.GenreName
                        </option>
                    }
                </select>
            </div>

            <!-- Price Range -->
            <div class="col-md-2">
                <select name="priceRange" class="form-select">
                    <option value="">💰 All Prices</option>
                    <option value="0-10">$0 - $10</option>
                    <option value="10-25">$10 - $25</option>
                    <option value="25-50">$25 - $50</option>
                    <option value="50-100">$50 - $100</option>
                    <option value="100+">$100+</option>
                </select>
            </div>

            <!-- Sort By -->
            <div class="col-md-2">
                <select name="sortBy" class="form-select">
                    <option value="">🔄 Sort By</option>
                    <option value="name">📝 Name (A-Z)</option>
                    <option value="name_desc">📝 Name (Z-A)</option>
                    <option value="price">💵 Price (Low-High)</option>
                    <option value="price_desc">💵 Price (High-Low)</option>
                    <option value="newest">🆕 Newest First</option>
                </select>
            </div>

            <!-- Search Button -->
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-1"></i>Search
                </button>
            </div>
        </div>
    </form>
</div>

<!-- MAIN LAYOUT -->
<div class="shop-layout">

    <!-- LEFT SIDEBAR -->
    <div class="sidebar">
        <h5>📂 Categories</h5>

        <a class="category-item d-block text-decoration-none text-dark"
           href="/Home/Index">
            All Books
        </a>

        @foreach (var g in Model.Genres)
        {
            <a class="category-item d-block text-decoration-none text-dark"
               href="/Home/Index?genreId=@g.Id">
                @g.GenreName
            </a>
        }
    </div>

    <!-- RIGHT CONTENT -->
    <div>

        <div class="book-grid">

            @if (Model.Books != null && Model.Books.Any())
            {
                foreach (var book in Model.Books)
                {
                    <div class="book-card">

                        <img class="book-img"
                             src="@(string.IsNullOrEmpty(book.Image) ? "/Images/NoImage.png" : "/images/" + book.Image)" />

                        <div class="book-body">

                            <a href="/Book/Details/@book.Id" class="text-decoration-none">
                                <div class="title">@book.BookName</div>
                            </a>
                            <div class="author">by @book.AuthorName</div>

                            <div class="price">$@book.Price.ToString("F2")</div>

                            <div class="d-flex gap-2">
                                <a href="/Cart/AddItem?bookId=@book.Id"
                                   class="btn btn-primary btn-sm flex-fill">
                                    🛒 Add to Cart
                                </a>

                                <button class="btn btn-outline-danger btn-sm wishlist-btn"
                                        data-book-id="@book.Id"
                                        onclick="toggleWishlist(@book.Id)">
                                    ❤️
                                </button>
                            </div>

                        </div>

                    </div>
                }
            }
            else
            {
                <div class="alert alert-warning">
                    No books found
                </div>
            }

        </div>

    </div>

</div>

@section Scripts {
    <script>
        async function toggleWishlist(bookId) {
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                const response = await fetch(`/Wishlist/IsInWishlist?bookId=${bookId}`);
                const isInWishlist = await response.json();

                if (isInWishlist) {
                    // Remove from wishlist
                    const removeResponse = await fetch('/Wishlist/RemoveFromWishlist', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: `bookId=${bookId}&__RequestVerificationToken=${token}`
                    });

                    if (removeResponse.ok) {
                        updateWishlistButton(bookId, false);
                    }
                } else {
                    // Add to wishlist
                    const addResponse = await fetch('/Wishlist/AddToWishlist', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: `bookId=${bookId}&__RequestVerificationToken=${token}`
                    });

                    if (addResponse.ok) {
                        updateWishlistButton(bookId, true);
                    }
                }
            } catch (error) {
                console.error('Error toggling wishlist:', error);
            }
        }

        function updateWishlistButton(bookId, isInWishlist) {
            const button = document.querySelector(`[data-book-id="${bookId}"]`);
            if (button) {
                button.innerHTML = isInWishlist ? '❤️' : '🤍';
                button.className = isInWishlist ? 'btn btn-danger btn-sm wishlist-btn' : 'btn btn-outline-secondary btn-sm wishlist-btn';
            }
        }

        // Initialize wishlist buttons on page load
        document.addEventListener('DOMContentLoaded', async function() {
            const buttons = document.querySelectorAll('.wishlist-btn');
            for (const button of buttons) {
                const bookId = button.getAttribute('data-book-id');
                try {
                    const response = await fetch(`/Wishlist/IsInWishlist?bookId=${bookId}`);
                    const isInWishlist = await response.json();
                    updateWishlistButton(bookId, isInWishlist);
                } catch (error) {
                    console.error('Error checking wishlist status:', error);
                }
            }
        });
    </script>
}




