@model AnalyticsDashboardViewModel
@{
    ViewData["Title"] = "Analytics Dashboard";
    Layout = "_AdminLayout";
}

<style>
    .dashboard-container {
        padding: 20px;
        background: #f8fafc;
        min-height: 100vh;
    }

    .stats-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        border-left: 4px solid #667eea;
        transition: transform 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-5px);
    }

    .stat-value {
        font-size: 2.5rem;
        font-weight: bold;
        color: #2d3748;
        margin-bottom: 5px;
    }

    .stat-label {
        color: #718096;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .charts-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
    }

    .chart-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .chart-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 20px;
    }

    .tables-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .table-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .table-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 20px;
    }

    .table-responsive {
        max-height: 400px;
        overflow-y: auto;
    }

    .table {
        margin-bottom: 0;
    }

    .table th {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        font-weight: 600;
        color: #2d3748;
        padding: 12px;
    }

    .table td {
        padding: 12px;
        border-bottom: 1px solid #e2e8f0;
    }

    .badge-low-stock {
        background: #fed7d7;
        color: #c53030;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.8rem;
    }

    .status-badge {
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 500;
    }

    .status-pending {
        background: #fef5e7;
        color: #d69e2e;
    }

    .status-processing {
        background: #ebf8ff;
        color: #3182ce;
    }

    .status-completed {
        background: #f0fff4;
        color: #38a169;
    }

    .status-cancelled {
        background: #fed7d7;
        color: #c53030;
    }

    @@media (max-width: 768px) {
        .charts-container,
        .tables-container {
            grid-template-columns: 1fr;
        }

        .stats-cards {
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        }
    }
</style>

<div class="dashboard-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-graph-up me-2"></i>Analytics Dashboard</h2>
        <small class="text-muted">Last updated: @DateTime.Now.ToString("MMM dd, yyyy HH:mm")</small>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-cards">
        <div class="stat-card">
            <div class="stat-value">$@Model.TotalSales.ToString("N0")</div>
            <div class="stat-label">Total Sales</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@Model.TotalOrders.ToString("N0")</div>
            <div class="stat-label">Total Orders</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@Model.TotalCustomers.ToString("N0")</div>
            <div class="stat-label">Total Customers</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@Model.TotalBooks.ToString("N0")</div>
            <div class="stat-label">Total Books</div>
        </div>
    </div>

    <!-- Charts -->
    <div class="charts-container">
        <div class="chart-card">
            <div class="chart-title">Monthly Sales Trend</div>
            <canvas id="salesChart" width="400" height="200"></canvas>
        </div>
        <div class="chart-card">
            <div class="chart-title">Sales by Genre</div>
            <canvas id="genreChart" width="400" height="200"></canvas>
        </div>
    </div>

    <!-- Tables -->
    <div class="tables-container">
        <div class="table-card">
            <div class="chart-title">Top Selling Books</div>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Book Title</th>
                            <th>Author</th>
                            <th>Units Sold</th>
                            <th>Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var book in Model.TopSellingBooks)
                        {
                            <tr>
                                <td>@book.BookName</td>
                                <td>@book.AuthorName</td>
                                <td>@book.TotalSold</td>
                                <td>$@book.TotalRevenue.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="table-card">
            <div class="chart-title">Low Stock Alert</div>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Book Title</th>
                            <th>Current Stock</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stock in Model.LowStockBooks)
                        {
                            <tr>
                                <td>@(stock.Book?.BookName ?? "Unknown Book")</td>
                                <td>@stock.Quantity</td>
                                <td>
                                    <span class="badge-low-stock">
                                        @if (stock.Quantity == 0)
                                        {
                                            @:Out of Stock
                                        }
                                        else
                                        {
                                            @:Low Stock
                                        }
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="table-card mt-4">
        <div class="chart-title">Recent Orders</div>
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.RecentOrders)
                    {
                        var orderStatus = order.OrderStatus?.StatusName ?? "Unknown";
                        <tr>
                            <td>#@order.Id</td>
                            <td>@order.User?.UserName</td>
                            <td>@order.OrderDetails.Sum(od => od.Quantity)</td>
                            <td>$@order.OrderDetails.Sum(od => od.UnitPrice * od.Quantity).ToString("N2")</td>
                            <td>
                                <span class="status-badge status-@orderStatus.ToLowerInvariant()">
                                    @orderStatus
                                </span>
                            </td>
                            <td>@order.CreateDate.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Sales Chart
        fetch('/Analytics/GetSalesData')
            .then(response => response.json())
            .then(data => {
                const ctx = document.getElementById('salesChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: data.map(item => item.month),
                        datasets: [{
                            label: 'Monthly Sales ($)',
                            data: data.map(item => item.sales),
                            borderColor: '#667eea',
                            backgroundColor: 'rgba(102, 126, 234, 0.1)',
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value) {
                                        return '$' + value.toLocaleString();
                                    }
                                }
                            }
                        }
                    }
                });
            });

        // Genre Sales Chart
        fetch('/Analytics/GetGenreSalesData')
            .then(response => response.json())
            .then(data => {
                const ctx = document.getElementById('genreChart').getContext('2d');
                new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: data.map(item => item.genre),
                        datasets: [{
                            data: data.map(item => item.sales),
                            backgroundColor: [
                                '#667eea',
                                '#764ba2',
                                '#f093fb',
                                '#f5576c',
                                '#4facfe',
                                '#00f2fe',
                                '#43e97b',
                                '#38f9d7'
                            ]
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: {
                                position: 'bottom'
                            }
                        }
                    }
                });
            });
    </script>
}
